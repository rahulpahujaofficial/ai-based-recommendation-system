# ─── Flask ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
FLASK_DEBUG=false
PORT=5000

# ─── Database ────────────────────────────────────────────
# SQLite (default — no extra setup needed)
DATABASE_URL=sqlite:///recoai.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/recoai

# ─── Gemini API ──────────────────────────────────────────
GEMINI_API_KEY=AIzaSyBwLjwjqFcPNaMjJ5F4JAzw65-VZAueYL8
GEMINI_MODEL=gemini-1.5-flash

# ─── Recommendation Engine ───────────────────────────────
# "gemini"  → AI-powered (requires GEMINI_API_KEY)
# "custom"  → content-based + collaborative filtering (no API key needed)
RECOMMENDATION_ENGINE=gemini
MAX_RECOMMENDATIONS=6

# ─── URLs ────────────────────────────────────────────────
# Backend URL (used inside generated embed codes)
WIDGET_BASE_URL=http://localhost:5000

# Frontend URL (CORS origin)
FRONTEND_URL=http://localhost:5173
